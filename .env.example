DOKU_CLIENT_ID="BRN-0229-1783394866076"
DOKU_CLIENT_KEY="Mid-client-pN4rpM9vXVwAT8JP"
DOKU_SECRET_KEY="SK-c1pC2u9lDrwLpYdVz05v"
