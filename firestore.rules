rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Admins list
    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    // Support Chats
    match /supportChats/{threadId} {
      allow read, write: if isAdmin();
      allow read, create, update: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
      
      match /messages/{messageId} {
        allow read, write: if isAdmin();
        allow read, create: if isSignedIn() && get(/databases/$(database)/documents/supportChats/$(threadId)).data.userId == request.auth.uid;
      }
    }
  }
}
