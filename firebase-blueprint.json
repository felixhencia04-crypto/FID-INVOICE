{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profiles and subscription data",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "businessName": { "type": "string" },
        "phone": { "type": "string" },
        "plan": { "type": "string" },
        "status": { "type": "string" },
        "expiryDate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["fullName", "email"]
    },
    "SupportThread": {
      "title": "Support Thread",
      "description": "Metadata for a support chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastUpdated": { "type": "string" },
        "timestamp_ms": { "type": "number" },
        "unreadForUser": { "type": "boolean" },
        "unreadForOwner": { "type": "boolean" },
        "status": { "type": "string" }
      },
      "required": ["userId", "userName", "status"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "An individual message in a support thread",
      "type": "object",
      "properties": {
        "sender": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "attachment": { "type": "object" },
        "timestamp": { "type": "string" },
        "timestamp_ms": { "type": "number" }
      },
      "required": ["sender", "senderName", "timestamp_ms"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/supportChats/{threadId}": {
      "schema": "SupportThread",
      "description": "Support chat thread metadata"
    },
    "/supportChats/{threadId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Individual messages in a thread"
    }
  }
}
